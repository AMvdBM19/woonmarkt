# WoonMarkt Docker Environment Configuration
# Copy this file to .env and fill in your production values
# IMPORTANT: .env must NOT be committed to git

# Server
PORT=3001
NODE_ENV=production

# MongoDB (local Docker container)
MONGO_URI=mongodb://woonmarkt-mongo:27017/house-marketplace

# Authentication — generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_strong_random_string

# OpenAI API key for description improvement and NL search
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Maps API key (for address autocomplete and map embeds)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=https://woonmarkt.monoliet.cloud

# Logging
LOG_LEVEL=info
